{
  "manifest_version": 3,
  "name": "OmniFlow",
  "version": "0.2.2",
  "description": "Phase 2.2 — Composer Inspector for DOM button discovery and targeting.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "OmniFlow"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}
